{
  "name": "git-lfs-server",
  "version": "1.0.0",
  "description": "Private Git LFS Server - Electron Desktop App",
  "main": "main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:server": "node server/index.js",
    "build": "vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "preview": "vite preview"
  },
  "dependencies": {
    "koa": "^2.15.3",
    "@koa/router": "^12.0.1",
    "koa-body": "^6.0.1",
    "@koa/cors": "^5.0.0",
    "koa-static": "^5.0.0",
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.5",
    "vue": "^3.5.13",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.gitlfs.server",
    "productName": "Git LFS Server",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main/**/*",
      "server/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
