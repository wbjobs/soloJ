{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@ecs/*": ["src/ecs/*"],
      "@components/*": ["src/components/*"],
      "@systems/*": ["src/systems/*"],
      "@map/*": ["src/map/*"],
      "@network/*": ["src/network/*"],
      "@db/*": ["src/db/*"],
      "@game/*": ["src/game/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
