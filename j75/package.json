{
  "name": "collab-editor-backend",
  "version": "1.0.0",
  "description": "Offline-first collaborative editing backend with CRDT (Yjs), WebSocket sync, RESTful API, MongoDB persistence, and JWT auth",
  "main": "dist/index.js",
  "bin": {
    "collab-logs": "./dist/cli/export-logs.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "cli:list": "ts-node src/cli/export-logs.ts list",
    "cli:export": "ts-node src/cli/export-logs.ts export"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "yjs": "^13.6.10",
    "mongoose": "^8.1.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.1",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "lib0": "^0.2.88"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2"
  }
}
