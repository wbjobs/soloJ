{
  "name": "electron-note-app",
  "version": "1.0.0",
  "description": "A note-taking application with Electron, Express, and MongoDB",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run server\" \"npm run electron\"",
    "server": "node src/server/server.js",
    "electron": "electron .",
    "install-deps": "npm install"
  },
  "keywords": [
    "electron",
    "notes",
    "mongodb",
    "editor"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
