    "electron": "^28.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "monaco-editor": "^0.44.0",
    "markdown-it": "^13.0.2"
  }
}
